// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
//  url      = env("DATABASE_URL")
}


// =======================
// ENUMS
// =======================

enum PrepArea {
  KITCHEN
  BAR
}

enum Departments {
  KITCHEN
  BAR
  SERVICE
  OPERATIONS
  MANAGEMENT
}

enum OrderStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SERVED
  PAID
  CANCELLED
}

enum OrderItemStatus {
  PENDING
  PREPARING
  READY
  SERVED
  CANCELLED
}

enum KitchenOrderStatus {
  PENDING
  PREPARING
  READY
  CANCELLED
}

enum BarOrderStatus {
  PENDING
  READY
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  ONLINE
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

// =======================
// INVENTORY ENUMS (kept for status and location)
// =======================

enum InventoryStatus {
  NORMAL
  LOW
  CRITICAL
}

enum InventoryLocation {
  KITCHEN
  BAR
  STORAGE
  WALKIN_COOLER
  FREEZER
  DRY_STORAGE
}

// =======================
// INVENTORY REFERENCE MODELS (CRUDable)
// =======================

model InventoryCategory {
  id          Int    @id @default(autoincrement())
  name        String @unique
  description String?
  isActive    Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  supplierId  Int? // New foreign key
  supplier    Supplier? @relation(fields: [supplierId], references: [id]) // New relation

  inventoryItems InventoryItem[]
}

model InventoryUnit {
  id          Int    @id @default(autoincrement())
  name        String @unique
  type        String
  symbol      String?
  description String?
  isActive    Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

 
}

// =======================
// MENU ADDONS AND SIDES
// =======================

model MenuAddon {
  id          Int     @id @default(autoincrement())
  name        String
  description String?
  price       Float
  isAvailable Boolean @default(true)

  // Relationships
  menuItems   MenuItem[] @relation("MenuItemAddons")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  /// Additional items that can be added to menu items (e.g., extra cheese, bacon, etc.)
  /// Stored as reference data to avoid duplication in order items
}

model MenuSideDish {
  id          Int     @id @default(autoincrement())
  name        String
  description String?
  price       Float
  isAvailable Boolean @default(true)

  // Relationships
  menuItems   MenuItem[] @relation("MenuItemSideDishes")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  /// Side dishes that can be selected with menu items (e.g., fries, salad, etc.)
  /// Stored as reference data to avoid duplication in order items
}


// ======================
// MENU CATEGORIES
// ======================

model MenuCategory {
  id          Int    @id @default(autoincrement())
  name        String @unique
  description String?
  prepArea    PrepArea @default(KITCHEN)
  isActive    Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  menuItems   MenuItem[]
}

// =======================
// MENU
// =======================

model MenuItem {
  id          Int    @id @default(autoincrement())
  name        String
  description String?
  price       Float
  isAvailable Boolean   @default(true)

  prepArea    PrepArea

  // Category and metadata
  categoryId     Int
  rating         Float?        @default(0)
  cost           Float?
  prepTime       Int?          // in minutes
  calories       Int?
  servingSize    String?

  // Ingredients and dietary information
  ingredients    String[]      @default([])
  allergens      String[]      @default([])
  dietaryOptions String[]      @default([])

  // Feature flags
  featured       Boolean?      @default(false)
  seasonal       Boolean?      @default(false)

  // Extras configuration flags
  hasAddons      Boolean?      @default(false)
  requiresSideDish Boolean?   @default(false)

  // Addons and Side Dishes relationships
  addons       MenuAddon[]   @relation("MenuItemAddons")
  sideDishes   MenuSideDish[] @relation("MenuItemSideDishes")

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  orderItems  OrderItem[]

  menuCategory MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
}

// =======================
// ORDERS
// =======================
model Order {
  id           Int           @id @default(autoincrement())
  orderNumber  Int

  tableNumber  Int?
  status       OrderStatus   @default(PENDING)
  customerName String?
  waiter       String?
  guestCount   Int?

  // Calculated total amount
  total        Float?        @default(0)

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  orderItems   OrderItem[]
  kitchenOrder KitchenOrder?
  barOrder     BarOrder?
  payments     Payment[]
}

model Payment {
  id            Int            @id @default(autoincrement())
  orderId       Int
  receiptNumber String?         @unique   // Revert to required when reinstating db
  order         Order          @relation(fields: [orderId], references: [id])
  amount        Float
  paymentMethod PaymentMethod
  status        PaymentStatus  @default(PENDING)
  transactionId String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

// =======================
// ORDER ITEMS
// =======================

model OrderItem {
  id          Int           @id @default(autoincrement())
  orderId     Int
  menuItemId  Int
  quantity    Int
  price       Float
  notes       String?
  selectedSideDishes Int[] @default([])
  selectedAddons     Int[] @default([])

  /// References to selected side dishes (IDs from MenuSideDish)
  /// This approach stores only references to avoid data duplication
  /// while maintaining the ability to query full details when needed
  ///
  /// Example: If a customer orders a steak with fries and salad,
  /// this array would contain [fries_id, salad_id]

  /// References to selected addons (IDs from MenuAddon)
  /// Similar to side dishes, stores only references for efficiency
  ///
  /// Example: If a customer adds extra cheese and bacon to a burger,
  /// this array would contain [cheese_id, bacon_id]

  prepArea    PrepArea
  status      OrderItemStatus @default(PENDING)

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  order       Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem   MenuItem        @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  kitchenOrderId Int?
  barOrderId     Int?

  kitchenOrder   KitchenOrder? @relation(fields: [kitchenOrderId], references: [id], onDelete: SetNull)
  barOrder       BarOrder?     @relation(fields: [barOrderId], references: [id], onDelete: SetNull)

  /// Indexes for better query performance on side dishes and addons
  @@index([selectedSideDishes])
  @@index([selectedAddons])
}

// =======================
// KITCHEN ORDERS
// =======================

model KitchenOrder {
  id        Int                 @id @default(autoincrement())
  orderId  Int                 @unique
  status   KitchenOrderStatus  @default(PENDING)

  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  order     Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  items     OrderItem[]
}

// =======================
// BAR ORDERS
// =======================

model BarOrder {
  id        Int              @id @default(autoincrement())
  orderId  Int              @unique
  status   BarOrderStatus   @default(PENDING)

  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  order     Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  items     OrderItem[]
}

// =======================
// INVENTORY MODELS
// =======================

model InventoryItem {
  id          Int    @id @default(autoincrement())
  name        String
  description String?
  sku         String? @unique
  categoryId  Int  @default(1)
  category    InventoryCategory @relation(fields: [categoryId], references: [id])
  unit        String

  //Departments
  department  String[] @default(["KITCHEN"])

  // Quantity and stock management
  quantity    Float   @default(0)
  minStock    Float?  @default(0)
  maxStock    Float?

  // Pricing and supplier info
  price       Float   @default(0)
  supplier    String?

  // Location and tracking
  location    InventoryLocation?
  storageLocation String? // Specific location details

  // Status and timestamps
  status      InventoryStatus @default(NORMAL)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relationships
  transactions       InventoryTransaction[]
  stockRequests      StockRequestItem[]
  purchaseOrderItems PurchaseOrderItem[]
  goodsReceivingItems GoodsReceivingItem[]
  batches            Batch[]
  departmentInventories DepartmentInventory[]
  adjustments        InventoryAdjustment[]
}

model DepartmentInventory {
  id              Int         @id @default(autoincrement())
  inventoryItemId Int
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  department      Departments // Use the existing enum
  quantity        Float       @default(0)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@unique([inventoryItemId, department]) // An item can only have one entry per department
}

// Inventory transaction model for tracking movements
model InventoryTransaction {
  id          Int    @id @default(autoincrement())
  itemId      Int
  quantity    Float
  transactionType String // "IN", "OUT", "ADJUSTMENT", "TRANSFER"
  reference   String? // Purchase order, usage reference, etc.
  notes       String?
  createdAt   DateTime @default(now())

  item        InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
}

// Stock request model for inventory requests
model StockRequest {
  id          Int    @id @default(autoincrement())
  requestId   String @unique
  status      String @default("pending") // pending, approved, rejected, fulfilled
  requestedBy String?
  requestedFrom Departments? // KITCHEN or BAR - who is requesting
  requestedAt DateTime @default(now())
  approvedAt  DateTime?
  fulfilledAt DateTime?

  // Relationship to inventory items (many-to-many)
  requestItems StockRequestItem[]
}

// Stock request items (junction table)
model StockRequestItem {
  id          Int    @id @default(autoincrement())
  requestId   Int
  itemId      Int
  quantity    Float
  status      String @default("pending")

  request     StockRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  item        InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
}

// =======================
// NEW ENUMS
// =======================

enum PurchaseOrderStatus {
  PENDING
  APPROVED
  ORDERED
  PARTIALLY_RECEIVED
  COMPLETED
  CANCELLED
}

// =======================
// SUPPLIER MODELS
// =======================

enum SupplierStatus {
  ACTIVE
  INACTIVE
  BLACKLISTED
}
model Supplier {
  id               Int              @id @default(autoincrement())
  name             String           @unique
  contactPerson    String?
  email            String?          @unique
  phone            String?
  address          String?
  status           SupplierStatus         @default(ACTIVE) // active, inactive, blacklisted  
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  purchaseOrders     PurchaseOrder[]
  goodsReceivings    GoodsReceiving[]
  inventoryCategories InventoryCategory[] // New relation
}

// =======================
// PURCHASE ORDER MODELS
// =======================
model PurchaseOrder {
  id                 Int                  @id @default(autoincrement())
  poNumber           String               @unique // Purchase Order Number
  supplierId         Int
  supplier           Supplier             @relation(fields: [supplierId], references: [id])
  status             PurchaseOrderStatus  @default(PENDING)
  notes              String?
  orderedAt          DateTime             @default(now())
  expectedDeliveryAt DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  items              PurchaseOrderItem[]
  goodsReceivings    GoodsReceiving[]
}

model PurchaseOrderItem {
  id                 Int          @id @default(autoincrement())
  purchaseOrderId    Int
  purchaseOrder      PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  inventoryItemId    Int
  inventoryItem      InventoryItem @relation(fields: [inventoryItemId], references: [id])
  quantityOrdered    Float
  quantityReceived   Float        @default(0)
  unitPrice          Float
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
}

// =======================
// GOODS RECEIVING MODELS
// =======================
model GoodsReceiving {
  id              Int                @id @default(autoincrement())
  grnNumber       String             @unique // Goods Received Note Number
  purchaseOrderId Int?
  purchaseOrder   PurchaseOrder?     @relation(fields: [purchaseOrderId], references: [id])
  supplierId      Int
  supplier        Supplier           @relation(fields: [supplierId], references: [id])
  receivedAt      DateTime           @default(now())
  notes           String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  receivedItems   GoodsReceivingItem[]
}

model GoodsReceivingItem {
  id                 Int          @id @default(autoincrement())
  goodsReceivingId   Int
  goodsReceiving     GoodsReceiving @relation(fields: [goodsReceivingId], references: [id], onDelete: Cascade)
  inventoryItemId    Int
  inventoryItem      InventoryItem @relation(fields: [inventoryItemId], references: [id])
  quantityReceived   Float
  batchId            Int?
  batch              Batch?       @relation(fields: [batchId], references: [id]) // Connects to a specific batch
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
}

// =======================
// BATCH MODELS
// =======================
model Batch {
  id                   Int                @id @default(autoincrement())
  batchNumber          String             @unique
  inventoryItemId      Int
  inventoryItem        InventoryItem      @relation(fields: [inventoryItemId], references: [id])
  quantity             Float
  receivedAt           DateTime           @default(now())
  expiryDate           DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  goodsReceivingItem   GoodsReceivingItem[] // Batches can be linked to multiple GRN items (e.g. partial receipts)
  adjustments          InventoryAdjustment[]
}

// =======================
// INVENTORY ADJUSTMENT MODELS
// =======================

model AdjustmentReason {
  id          Int    @id @default(autoincrement())
  name        String @unique
  type        String // "increase", "decrease", "both"
  description String?
  isActive    Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  adjustments InventoryAdjustment[]
}

model InventoryAdjustment {
  id              Int                @id @default(autoincrement())
  adjustmentNumber String            @unique
  inventoryItemId Int
  inventoryItem   InventoryItem      @relation(fields: [inventoryItemId], references: [id])
  batchId         Int?
  batch           Batch?            @relation(fields: [batchId], references: [id])
  adjustmentReasonId Int
  adjustmentReason AdjustmentReason @relation(fields: [adjustmentReasonId], references: [id])
  adjustmentType   String // "increase", "decrease"
  quantity        Float
  previousQuantity Float
  newQuantity     Float
  notes           String?
  adjustedBy      String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([inventoryItemId])
  @@index([batchId])
}

model ExpenseCategory {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  expenses    Expense[]
}

model Expense {
  id              Int              @id @default(autoincrement())
  amount          Float
  date            DateTime
  description     String?
  categoryId      Int
  category        ExpenseCategory  @relation(fields: [categoryId], references: [id])
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

model Table {
  id           Int                @id @default(autoincrement())
  number       Int                @unique
  capacity     Int
  status       TableStatus        @default(AVAILABLE)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  reservations ReservationTable[] // Updated relationship
}

model Reservation {
  id            Int                @id @default(autoincrement())
  customerName  String
  customerPhone String
  customerEmail String?
  date          DateTime
  numberOfGuests Int
  status        ReservationStatus  @default(PENDING)
  notes         String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  tables        ReservationTable[] // New relationship
}

// New join table
model ReservationTable {
  reservationId Int
  tableId       Int
  reservation   Reservation @relation(fields: [reservationId], references: [id])
  table         Table       @relation(fields: [tableId], references: [id])

  @@id([reservationId, tableId])
}

// =======================
// SETTINGS MODEL
// =======================
model Setting {
  id                Int      @id @default(autoincrement())
  key               String   @unique
  value             String?
  description       String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

// =======================
// DISSATISFACTION MODEL (Kitchen Issues)
// =======================

enum DissatisfactionStatus {
  PENDING
  REMADE
  RESOLVED
  REFUNDED
}

model Dissatisfaction {
  id            Int                   @id @default(autoincrement())
  orderId       Int
  tableNumber   Int
  itemName      String
  reason        String
  status        DissatisfactionStatus @default(PENDING)
  resolution    String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
}

// =======================
// BAR RETURN MODEL (Bar Issues)
// =======================

enum BarReturnStatus {
  PENDING
  REMADE
  RESOLVED
  REFUNDED
}

model BarReturn {
  id            Int              @id @default(autoincrement())
  orderId       Int
  tableNumber   Int
  itemName      String
  reason        String
  status        BarReturnStatus @default(PENDING)
  resolution    String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

// =======================
// DEPARTMENT MODEL
// =======================

model Department {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  staffRoles  StaffRole[]
  staff       Staff[]
}

// =======================
// STAFF ROLE MODEL
// =======================

model StaffRole {
  id            Int         @id @default(autoincrement())
  name          String      @unique
  description   String?
  departmentId  Int?
  department    Department? @relation(fields: [departmentId], references: [id])
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  staff         Staff[]
}

// =======================
// STAFF/EMPLOYEE MODEL
// =======================

model Staff {
  id                Int               @id @default(autoincrement())
  firstName         String
  lastName          String
  email             String?           @unique
  phone             String?
  roleId            Int?
  role              StaffRole?        @relation(fields: [roleId], references: [id])
  departmentId      Int?
  department        Department?       @relation(fields: [departmentId], references: [id])
  hireDate          DateTime          @default(now())
  status            String            @default("ACTIVE")
  imageUrl          String?
  address           String?
  emergencyContact  String?
  notes             String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  // Relation to User (one staff can have one user account)
  user              User?
}

// =======================
// PERMISSION MODEL
// =======================

model Permission {
  id          Int       @id @default(autoincrement())
  name        String    @unique // e.g., "orders.create", "inventory.view", "staff.manage"
  description String?
  category    String    // e.g., "orders", "inventory", "staff", "reports", "settings"
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  userGroups           UserGroupPermission[]
  permissionOverrides UserPermissionOverride[]
}

// =======================
// USER GROUP MODEL
// =======================

model UserGroup {
  id          Int       @id @default(autoincrement())
  name        String    @unique // e.g., "Admin", "Manager", "Waiter"
  description String?
  isDefault   Boolean   @default(false) // Default group for new users
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  users       User[]
  permissions UserGroupPermission[]
}

// =======================
// USER GROUP PERMISSION (Junction Table)
// =======================

model UserGroupPermission {
  id            Int        @id @default(autoincrement())
  userGroupId   Int
  permissionId  Int
  userGroup     UserGroup  @relation(fields: [userGroupId], references: [id], onDelete: Cascade)
  permission    Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userGroupId, permissionId])
}

// =======================
// USER MODEL
// =======================

model User {
  id              Int       @id @default(autoincrement())
  username        String    @unique
  email           String?   @unique
  passwordHash    String
  refreshToken    String?   // Store refresh token for session management
  staffId         Int?      @unique // Link to Staff (optional)
  staff           Staff?    @relation(fields: [staffId], references: [id])
  userGroupId     Int?
  userGroup       UserGroup? @relation(fields: [userGroupId], references: [id])
  isActive        Boolean   @default(true)
  lastLogin       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Manual permission overrides (these take precedence over userGroup permissions)
  permissionOverrides UserPermissionOverride[]
}

model UserPermissionOverride {
  id            Int        @id @default(autoincrement())
  userId        Int
  permissionId  Int
  allowed       Boolean    // true = grant, false = deny
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission    Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
}

